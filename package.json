{
  "name": "interviewiq",
  "private": true,
  "workspaces": [
    "app",
    "server",
    "packages/*"
  ],
  "scripts": {
    "dev:server": "npm run dev --workspace=server",
    "dev:app": "npm run start --workspace=app",
    "migrate": "npm run migrate --workspace=server",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down"
  },
  "allowScripts": {
    "esbuild@0.18.20": true,
    "esbuild@0.19.12": true,
    "esbuild@0.28.1": true,
    "esbuild@0.21.5": true,
    "bcrypt@5.1.1": true,
    "puppeteer@23.11.1": true,
    "fsevents@2.3.3": true
  }
}
