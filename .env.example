# Server
PORT=4000
DATABASE_URL=postgres://interviewiq:interviewiq@localhost:5432/interviewiq
JWT_SECRET=change-me-in-production

# Base URL used to build share links (POST /reports/:id/share). This must
# point at the app, not the backend API — the backend's /share/:token route
# returns raw JSON, not a page. Locally that's the Expo web dev server;
# in production this should be a proper universal-link domain with
# App Links (Android) / Associated Domains (iOS) configured so the link
# opens the native app directly, falling back to a web view of the same
# app/share/[token] route otherwise (not built in this MVP pass).
PUBLIC_BASE_URL=http://localhost:8082

# LLM provider selection: "anthropic" | "openai" | "ollama"
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Local model via Ollama (only used when LLM_PROVIDER=ollama). Install
# Ollama (https://ollama.com), run `ollama pull qwen2.5:7b` (or a larger
# Qwen2.5/Qwen3 model if your hardware supports it — anything with solid
# tool-calling support), and make sure `ollama serve` is running.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Web search backend for the local/Ollama provider, which has no built-in
# web search of its own (unlike Anthropic/OpenAI's hosted tool). Get a free
# key at https://tavily.com. Not needed for the anthropic/openai providers.
TAVILY_API_KEY=

# Mobile app (Expo) — read via EXPO_PUBLIC_* at build time
EXPO_PUBLIC_API_URL=http://localhost:4000
