# Server
PORT=4000
DATABASE_URL=postgres://interviewiq:interviewiq@localhost:5432/interviewiq
JWT_SECRET=change-me-in-production
PUBLIC_BASE_URL=http://localhost:4000

# LLM provider selection: "anthropic" | "openai"
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional dedicated web search provider (only needed if not using a
# provider's built-in web search tool)
SEARCH_API_KEY=

# Mobile app (Expo) — read via EXPO_PUBLIC_* at build time
EXPO_PUBLIC_API_URL=http://localhost:4000
